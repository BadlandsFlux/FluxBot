# ---- Fluxer instance -------------------------------------------------
# For the official instance leave these as-is. For self-hosting, point
# them at your own deployment (see README "Self-hosting" section).
FLUXER_API_BASE=https://api.fluxer.app/v1
FLUXER_GATEWAY_URL=
FLUXER_WEB_BASE=https://fluxer.app

# ---- Bot ---------------------------------------------------------------
FLUXER_BOT_TOKEN=your_bot_token_here
BOT_NAME=FluxBot
# Your own Fluxer user ID — gates the owner-only !info command.
BOT_OWNER_ID=
COMMAND_PREFIX=!
# Intents bitmask. 3243773 ~= guilds + members + messages + reactions + moderation.
# Adjust to match what your instance exposes; see README.
FLUXER_INTENTS=3243773

# ---- OAuth2 app used by the dashboard for "Login with Fluxer" ---------
# Create this application via POST /oauth2/applications (see README).
FLUXER_OAUTH_CLIENT_ID=your_client_id
FLUXER_OAUTH_CLIENT_SECRET=your_client_secret
FLUXER_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# ---- Dashboard -----------------------------------------------------------
# The dashboard refuses to start if this is left at the placeholder below,
# or under 16 characters. Generate a real one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SESSION_SECRET=change_me_to_a_long_random_string
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
# Set to the reverse proxy's IP if it's not on the same machine (see deploy/nginx-fluxbot.conf)
TRUSTED_PROXY_IPS=127.0.0.1
# Set to true once you're serving over HTTPS behind nginx
DASHBOARD_COOKIE_SECURE=false

# ---- Shared storage (real Postgres service) -------------------------------
# Both the bot process and the dashboard process connect to this same
# database. Run `psql` against it once with schema.sql (see README), or
# let `python -m common.db` create the tables for you.
DATABASE_URL=postgresql://fluxerbot:fluxerbot@localhost:5432/fluxerbot
DB_POOL_MIN=1
DB_POOL_MAX=10
